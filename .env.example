# Número de WhatsApp del dueño del bot (sin +, sin espacios, con código de país)
# Ejemplo Argentina: 5491112345678
# Ejemplo España:    34612345678
MY_NUMBER=

# JID del grupo de WhatsApp donde el bot va a operar
# Cómo obtenerlo: ver README → "Obtener el GROUP_JID"
# Formato: 120363XXXXXXXXXX@g.us
# Dejar vacío para que el bot responda en chat privado (al número de MY_NUMBER)
GROUP_JID=

# ID de la Google Sheet donde se guardan los registros
# Es el string largo en la URL: docs.google.com/spreadsheets/d/<SHEET_ID>/edit
GOOGLE_SHEET_ID=

# Backend de persistencia: "sheets" (Google Sheets) o "sqlite" (local, no requiere cuenta Google)
# Con sqlite, los datos se guardan en bot/data/bot.db
STORAGE=sheets

# Minutos de espera antes de enviar recordatorio si no se respondió un check-in
REMINDER_MINUTES=60

# Autenticación del dashboard web (dejar vacío para acceso libre en local)
DASHBOARD_USER=
DASHBOARD_PASS=

# Zona horaria para el scheduling y los reportes
# Lista completa: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# Ejemplos:
#   América del Sur:  America/Argentina/Buenos_Aires
#   España:           Europe/Madrid
#   México:           America/Mexico_City
TIMEZONE=America/Argentina/Buenos_Aires
